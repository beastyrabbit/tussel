{
  "name": "@tussel/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm -r --filter @tussel/core... run build"
  },
  "dependencies": {
    "@tonaljs/tonal": "^4.10.0",
    "@tussel/ir": "workspace:*",
    "@tussel/mini": "workspace:*"
  }
}
