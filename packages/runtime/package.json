    "@tussel/dsl": "workspace:*",
    "@tussel/ir": "workspace:*",
    "@tussel/mini": "workspace:*",
    "ajv": "^8.18.0",
    "chokidar": "^5.0.0",
    "esbuild": "^0.27.4",
    "picocolors": "^1.1.1",
    "typescript": "^5.9.3"
  }
