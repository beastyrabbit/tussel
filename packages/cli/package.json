{
  "name": "@tussel/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tussel": "./bin/tussel.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm -r --filter @tussel/cli... run build"
  },
  "dependencies": {
    "@tussel/runtime": "workspace:*",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
