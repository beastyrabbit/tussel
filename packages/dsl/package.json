{
  "name": "@tussel/dsl",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./globals": "./src/globals.d.ts"
  },
  "files": [
    "dist",
    "src/globals.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm -r --filter @tussel/dsl... run build"
  },
  "dependencies": {
    "@tussel/ir": "workspace:*"
  }
}
