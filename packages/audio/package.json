{
  "name": "@tussel/audio",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "pnpm -r --filter @tussel/audio... run build"
  },
  "dependencies": {
    "@julusian/midi": "^3.6.1",
    "@tussel/core": "workspace:*",
    "@tussel/ir": "workspace:*",
    "node-web-audio-api": "^1.0.8",
    "picocolors": "^1.1.1"
  }
}
