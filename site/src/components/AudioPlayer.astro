---
interface Props {
  /** Label shown above the player, e.g. "Tussel" */
  label: string;
  /** Path relative to site/public/, without extension. Base URL is prepended automatically. e.g. "audio/01-single-sound/tussel" */
  src: string;
}

const { label, src } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<div class="audio-card">
  <h4>{label}</h4>
  <audio controls preload="none">
    <source src={`${base}${src}.ogg`} type="audio/ogg" />
    <source src={`${base}${src}.mp3`} type="audio/mpeg" />
    Your browser does not support the audio element.
  </audio>
</div>
