{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.ref",
      "!**/.tussel-cache",
      "!**/coverage",
      "!**/dist",
      "!**/node_modules",
      "!site/src/**/*.astro",
      "!site/.astro",
      "!site-examples/**/*.strudel.js",
      "!site-examples/**/*.tidal"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 110
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
